PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/puzzle-platform
JWT_SECRET=replace_with_a_long_random_secret

# Frontend URL used in verification & password-reset emails
FRONTEND_URL=http://localhost:5173
APP_NAME=Puzzle Platform

# Optional: set true to skip sending mail and mark emails verified on signup (dev only)
# SKIP_EMAIL_VERIFICATION=true

# SMTP (when set, verification/reset emails are sent; otherwise links are logged to the console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
